# ============================================================
# HRMS Backend — Environment Variables
# Copy to .env for local dev (outside Docker)
# ============================================================

DATABASE_URL="postgresql://hrms:hrmspassword@localhost:5432/hrmsdb"

JWT_SECRET="change_this_to_a_long_random_secret_in_production"
JWT_EXPIRES_IN="7d"

PORT=3001

# URL of the frontend (used for CORS)
FRONTEND_URL="http://localhost:3000"
