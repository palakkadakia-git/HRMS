# ============================================================
# HRMS Frontend — Environment Variables
# Copy to .env.local for local dev
# ============================================================

# Public — exposed to the browser (for direct API calls from client)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Private — used only on the Next.js server (for rewrites / SSR)
# In Docker this should be the Docker service name
INTERNAL_API_URL=http://localhost:3001
