{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend — Next.js",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 3000
    },
    {
      "name": "Backend — NestJS",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "backend", "run", "start:dev"],
      "port": 3001
    },
    {
      "name": "Prisma Studio",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "backend", "run", "prisma:studio"],
      "port": 5555
    },
    {
      "name": "Full Stack — Docker Compose",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "port": 3000
    }
  ]
}
